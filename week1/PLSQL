Exercise 1: Control Structures
Scenario 1:

DECLARE
    -- Cursor to select eligible customers and their loans
    CURSOR c_elderly_customers IS
        SELECT c.customer_id, l.loan_id, l.interest_rate
        FROM customers c
        JOIN loans l ON c.customer_id = l.customer_id
        WHERE c.age > 60;
BEGIN
    FOR r_cust IN c_elderly_customers LOOP
        -- Apply a 1% discount to the current interest rate
        UPDATE loans
        SET interest_rate = r_cust.interest_rate - 1
        WHERE loan_id = r_cust.loan_id;
        
        DBMS_OUTPUT.PUT_LINE('Applied 1% discount to Loan ID: ' || r_cust.loan_id || ' for Customer ID: ' || r_cust.customer_id);
    END LOOP;
    
    COMMIT;
EXCEPTION
    WHEN OTHERS THEN
        ROLLBACK;
        DBMS_OUTPUT.PUT_LINE('Error updating interest rates: ' || SQLERRM);
END;

Scenario 2:

DECLARE
    CURSOR c_wealthy_customers IS
        SELECT customer_id, balance
        FROM customers
        WHERE balance > 10000;
BEGIN
    FOR r_cust IN c_wealthy_customers LOOP
        -- Updates the VIP flag. 
        -- Note: If IsVIP is a standard SQL column, use 'Y' or 1 since SQL lacks a native BOOLEAN type.
        UPDATE customers
        SET IsVIP = 'Y' 
        WHERE customer_id = r_cust.customer_id;
        
        DBMS_OUTPUT.PUT_LINE('Promoted Customer ID: ' || r_cust.customer_id || ' to VIP status.');
    END LOOP;
    
    COMMIT;
EXCEPTION
    WHEN OTHERS THEN
        ROLLBACK;
        DBMS_OUTPUT.PUT_LINE('Error updating VIP status: ' || SQLERRM);
END;

Scenario 3:

DECLARE
    CURSOR c_due_loans IS
        SELECT c.customer_id, c.customer_name, l.loan_id, l.due_date
        FROM customers c
        JOIN loans l ON c.customer_id = l.customer_id
        WHERE l.due_date BETWEEN SYSDATE AND SYSDATE + 30;
BEGIN
    DBMS_OUTPUT.PUT_LINE('--- LOAN DUE REMINDERS ---');
    
    FOR r_loan IN c_due_loans LOOP
        DBMS_OUTPUT.PUT_LINE('Reminder: Dear ' || r_loan.customer_name || 
                             ' (ID: ' || r_loan.customer_id || 
                             '), your Loan ID: ' || r_loan.loan_id || 
                             ' is due on ' || TO_CHAR(r_loan.due_date, 'YYYY-MM-DD') || '.');
    END LOOP;
END;
